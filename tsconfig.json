{
    "compilerOptions": {
        "target": "es2021",
        "module": "esnext",
        "lib": [
            "esnext",
            "dom"
        ],
        "jsx": "react",
        "declaration": true,
        "outDir": "dist",
        "rootDir": "lib",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "node",
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": [
        "lib"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}